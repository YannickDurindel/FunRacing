[layer_names]

3d_physics/layer_1="world"
3d_physics/layer_2="cars"
3d_physics/layer_3="checkpoints"
3d_physics/layer_4="pit_areas"
3d_physics/layer_5="drs_zones"

[network]

limits/debugger/max_chars_per_second=32768
limits/debugger/max_queued_messages=2048
